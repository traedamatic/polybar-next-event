# polybar-next-event configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────

# CalDAV server URL
# Fastmail: https://caldav.fastmail.com/dav/principals/user/YOUR_EMAIL/
CALENDAR_URL=https://caldav.fastmail.com/dav/principals/user/you@fastmail.com/

# CalDAV username (usually your email address)
CALENDAR_USERNAME=you@fastmail.com

# CalDAV password (use an app-specific password, NOT your login password)
# Fastmail: Settings → Privacy & Security → App Passwords → New App Password
CALENDAR_PASSWORD=your-app-password-here

# ── Optional ─────────────────────────────────────────────────

# Polling interval in seconds (default: 60)
# POLL_INTERVAL=60

# Urgency colors (hex format, default: Nord theme)
# > 1 hour away (green)
# COLOR_FAR=#A3BE8C
# 15-60 minutes away (yellow)
# COLOR_MEDIUM=#EBCB8B
# < 15 minutes away (red)
# COLOR_URGENT=#BF616A
